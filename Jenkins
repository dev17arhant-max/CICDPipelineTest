pipeline {
    agent any

    triggers {
        pollSCM('H/5 * * * *')
    }

    environment {
        IMAGE_NAME = 'rabin/cicdpipelinetest'        // CHANGE THIS
        DOCKERHUB  = credentials('dockerhub-creds')    // CHANGE THIS to your credential ID
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build Image') {
            steps {
                bat 'docker build -t %IMAGE_NAME%:%BUILD_NUMBER% -t %IMAGE_NAME%:latest .'
                // VS layout? use: -f MyApi/Dockerfile .
            }
        }

        stage('Login & Push') {
            steps {
                bat '''
                    echo %DOCKERHUB_PSW% | docker login -u %DOCKERHUB_USR% --password-stdin
                    docker push %IMAGE_NAME%:%BUILD_NUMBER%
                    docker push %IMAGE_NAME%:latest
                    docker logout
                '''
            }
        }
    }

    post {
        success {
            echo "Pushed ${IMAGE_NAME}:${BUILD_NUMBER} and :latest to Docker Hub"
        }
        failure {
            echo 'Build or push failed - check the stage logs above.'
        }
    }
}